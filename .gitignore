# Python virtual environment (large, regenerable)
.venv/
__pycache__/
*.pyc

# Downloaded dataset (auto-downloads on run; ~13 MB)
data/

# Local run logs
*.log

# SUMO generated artifacts (regenerated by the build/run scripts)
sumo/grid.net.xml
sumo/grid.rou.xml
sumo/grid.trips.xml
sumo/tripinfo_*.xml
sumo/stats_*.xml
